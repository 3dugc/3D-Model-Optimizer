{
  "name": "3d-model-optimizer",
  "version": "1.0.0",
  "description": "3D Model Optimizer - Node.js server for optimizing 3D model files with RESTful API",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --files src/index.ts",
    "dispatcher": "ts-node --files src/dispatcher/run-dispatcher.ts",
    "dispatcher:prod": "node dist/dispatcher/run-dispatcher.js",
    "monitor": "ts-node --files src/monitor/run-monitor.ts",
    "monitor:prod": "node dist/monitor/run-monitor.js",
    "worker": "ts-node --files src/worker/run-worker.ts",
    "worker:prod": "node dist/worker/run-worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "glb",
    "gltf",
    "3d",
    "optimization",
    "draco",
    "meshoptimizer",
    "texture-compression"
  ],
  "author": "",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0 <21.0.0"
  },
  "dependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "@types/cors": "^2.8.19",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "draco3d": "^1.5.7",
    "express": "^4.21.0",
    "helmet": "^8.1.0",
    "meshoptimizer": "^1.0.1",
    "multer": "^2.1.1",
    "mysql2": "^3.22.4",
    "obj2gltf": "^3.2.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "stl-reader": "^3.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.1"
  },
  "overrides": {
    "cesium": "1.138.0",
    "@cesium/engine": "22.3.0",
    "@cesium/widgets": "14.3.0",
    "cos-nodejs-sdk-v5": {
      "fast-xml-parser": "5.8.0",
      "conf": {
        "ajv": "8.20.0",
        "ajv-formats": "3.0.1"
      },
      "request": {
        "form-data": "2.5.5",
        "qs": "6.15.2",
        "tough-cookie": "4.1.4"
      }
    }
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.1",
    "fast-check": "^3.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^4.1.7"
  }
}
