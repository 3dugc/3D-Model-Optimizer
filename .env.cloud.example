# Control API
NODE_ENV=production
PORT=3000
API_KEY=change-me
# Optional scoped external API keys. Prefer this for partner systems.
# API_KEYS='[{"name":"partner-a","key":"replace-me","tenantId":"tenant-a","taskTypes":["model.optimize"],"scopes":["jobs:create","jobs:read","jobs:complete","jobs:result","upload:grant","cos:events"]}]'
API_BASE_URL=https://optimizer.example.com

# Async cloud runtime
CLOUD_PROVIDER=local
STATE_STORE_PROVIDER=local
DATABASE_URL=
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# For TencentDB MySQL, use:
# STATE_STORE_PROVIDER=mysql
# DATABASE_URL=mysql://user:password@mysql-host:3306/optimizer
JOB_STORE_PATH=data/cloud/jobs.json
ORDER_STORE_PATH=data/cloud/orders.json
CLOUD_LOCAL_OBJECT_ROOT=data/cloud/objects
DEFAULT_TASK_TYPE=model.optimize
JOB_MAX_ATTEMPTS=3
JOB_TIMEOUT_SECONDS=1800
JOB_LEASE_SECONDS=300
EXPIRED_JOB_RECOVERY_INTERVAL_SECONDS=30

# COS-compatible object layout
TENCENT_REGION=ap-nanjing
COS_INPUT_BUCKET=model-optimizer-1251022382
COS_OUTPUT_BUCKET=model-optimizer-1251022382
COS_UPLOAD_CREDENTIAL_TTL_SECONDS=1800
COS_DOWNLOAD_URL_TTL_SECONDS=900
# signed-url uses one-object short-lived PUT URLs. sts requires COS_UPLOAD_STS_ROLE_ARN.
COS_UPLOAD_GRANT_MODE=signed-url
COS_UPLOAD_STS_ROLE_ARN=

# Worker
WORKER_ID=worker-local-1
INSTANCE_ID=local-dev
WORKER_CONCURRENCY=1
WORKER_HEARTBEAT_INTERVAL_MS=10000
# 0 means stay alive. Elastic one-shot workers can set 900 to exit after 15 idle minutes.
WORKER_IDLE_EXIT_SECONDS=0
# Tencent Spot workers poll this URL for a 2-minute interruption notice.
WORKER_SPOT_TERMINATION_CHECK_URL=http://metadata.tencentyun.com/latest/meta-data/spot/termination-time
WORKER_SPOT_TERMINATION_POLL_MS=5000

# Callback
CALLBACK_TIMEOUT_SECONDS=10
CALLBACK_MAX_ATTEMPTS=6

# Billing
BILLING_MODE=mock
DEFAULT_JOB_PRICE_CENTS=800
WECHAT_PAY_NOTIFY_URL=https://optimizer.example.com/api/v1/payments/wechat/notify

# Tencent production wiring, used when CLOUD_PROVIDER=tencent
# Preferred production mode: bind a CAM role to the CVM/AS instances and leave permanent keys empty.
# When TENCENT_SECRET_ID/TENCENT_SECRET_KEY are empty, runtime clients read temporary credentials from CVM metadata.
TENCENT_CVM_ROLE_NAME=
TENCENT_CVM_ROLE_METADATA_URL=
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_TOKEN=
QUEUE_PROVIDER=tdmq-cmq
QUEUE_ENDPOINT=https://cmq-nj.public.tencenttdmq.com
QUEUE_NAME=optimizer-jobs
QUEUE_POLLING_WAIT_SECONDS=10

# Elastic Dispatcher
# Run as a separate process/container. It observes jobs in the shared DB and adjusts Tencent AS desired capacity.
DISPATCHER_PROVIDER=tencent-as
DISPATCHER_AS_GROUP_IDS=asg-pj6qaput
DISPATCHER_TASK_TYPE=model.optimize
DISPATCHER_INTERVAL_SECONDS=30
DISPATCHER_SLOTS_PER_INSTANCE=1
DISPATCHER_MIN_INSTANCES=0
DISPATCHER_MAX_INSTANCES=3
DISPATCHER_DRY_RUN=false

# WeChat Pay production wiring, used when BILLING_MODE=wechat_native
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_API_V3_KEY=
